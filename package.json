{
  "name": "agent-memory-manager",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "bash scripts/dev-desktop.sh",
    "build:desktop:debug": "tauri build --debug --bundles app --config src-tauri/tauri.dev.conf.json",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "profile:generate": "cargo run --manifest-path src-tauri/Cargo.toml --bin amm-profile-generate --",
    "profile:generate:codex": "cargo run --manifest-path src-tauri/Cargo.toml --bin amm-profile-generate -- --require-codex",
    "profile:verify": "node scripts/verify-profile-cache.mjs",
    "profile:verify:optional": "node scripts/verify-profile-cache.mjs --optional",
    "tauri": "tauri",
    "verify": "bash scripts/verify.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tanstack/react-query": "^5.90.12",
    "codemirror": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "lucide-react": "^0.555.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.15",
    "@tauri-apps/cli": "^2"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
