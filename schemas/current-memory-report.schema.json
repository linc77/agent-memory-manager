{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-memory-manager.local/schemas/current-memory-report.schema.json",
  "title": "Current Memory Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "generatedAt",
    "summary",
    "currentClaims",
    "staleClaims",
    "conflicts",
    "uncertainClaims",
    "suggestedCorrections",
    "metadata"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "mode": {
      "type": "string",
      "enum": ["curated", "full"]
    },
    "generatedAt": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "currentClaims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "staleClaims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflict"
      }
    },
    "uncertainClaims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "suggestedCorrections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suggestedCorrection"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourcePath", "startLine", "endLine", "summary"],
      "properties": {
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "subject",
        "field",
        "value",
        "scope",
        "status",
        "confidence",
        "rationale",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": ["global", "project", "tool", "writing", "rule", "unknown"]
        },
        "status": {
          "type": "string",
          "enum": ["current", "stale", "historical", "uncertain"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "detail", "confidence", "claimIds", "evidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "claimIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        }
      }
    },
    "suggestedCorrection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "reason",
        "content",
        "confidence",
        "affectedClaimIds",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "affectedClaimIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoryRoot", "inputEntries", "model"],
      "properties": {
        "memoryRoot": {
          "type": "string"
        },
        "inputEntries": {
          "type": "integer",
          "minimum": 0
        },
        "model": {
          "type": "string"
        }
      }
    }
  }
}
