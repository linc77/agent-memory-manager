{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-backplane.local/schemas/memory-profile.schema.json",
  "title": "Memory Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "sourceHash",
    "generator",
    "cachePath",
    "sections",
    "metadata"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "generatedAt": {
      "type": "string"
    },
    "sourceHash": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "cachePath": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "body", "evidence", "confidence", "stability"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80,
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "stability": {
          "type": "string",
          "enum": ["stable", "recent", "uncertain"]
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entryId", "sourcePath", "startLine", "endLine", "summary"],
      "properties": {
        "entryId": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoryRoot", "inputEntries", "currentEntries"],
      "properties": {
        "memoryRoot": {
          "type": "string"
        },
        "inputEntries": {
          "type": "integer",
          "minimum": 0
        },
        "currentEntries": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
