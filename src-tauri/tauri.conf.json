{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Memory Manager",
  "version": "0.1.2",
  "identifier": "com.linc.agent-memory-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "label": "main",
        "title": "Agent Memory Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGMTJDMDM0QUVERThBQjkKUldTNWl0NnVOTUFTZitSNWxjRFlyeVdJSDRMeXlGQXNWb3o2OHBrSk9KT2o4Q1k5NktjUDR0UXAK",
      "endpoints": [
        "https://github.com/linc77/agent-memory-manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
